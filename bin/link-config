#!/usr/bin/bash

ln -svf --backup ~/dot/i3/config ~/.config/i3/config
ln -svf --backup ~/dot/polybar/{config.ini,launch.sh} ~/.config/polybar/
ln -svf --backup ~/dot/zsh/.zshrc ~/.zshrc
ln -svf --backup ~/dot/systemd ~/.config/systemd
ln -svf --backup ~/dot/dunst ~/.config/dunst
ln -svf --backup ~/dot/rofi ~/.config/rofi
ln -svf --backup ~/dot/btop/btop.conf ~/.config/btop/btop.conf
ln -svf --backup ~/dot/ranger ~/.config/ranger
ln -svf --backup ~/dot/gitui ~/.config/gitui

echo '[include]
    path = ~/dot/git/config' >~/.gitconfig
